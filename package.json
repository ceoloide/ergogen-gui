{
  "name": "ergogen-gui",
  "version": "0.17.0",
  "description": "A web-based GUI for Ergogen, the ergonomic keyboard layout generator.",
  "license": "MIT",
  "private": false,
  "dependencies": {
    "@jscad/csg": "0.7.0",
    "@jscad/stl-serializer": "0.1.3",
    "@monaco-editor/react": "^4.6.0",
    "@react-three/drei": "^9.92.0",
    "@react-three/fiber": "^8.15.0",
    "ergogen": "^4.2.1",
    "file-saver": "^2.0.5",
    "js-yaml": "^4.1.0",
    "jszip": "^3.10.1",
    "lodash.debounce": "^4.0.8",
    "lz-string": "^1.5.0",
    "makerjs": "^0.19.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-easy-panzoom": "^0.4.4",
    "react-hotkeys-hook": "^5.1.0",
    "react-router-dom": "^7.9.3",
    "react-use": "^17.5.0",
    "styled-components": "^6.1.8",
    "three": "^0.180.0",
    "typescript": "^5.4.5",
    "workbox-cacheable-response": "^7.4.1",
    "workbox-core": "^7.4.1",
    "workbox-expiration": "^7.4.1",
    "workbox-google-analytics": "^7.4.1",
    "workbox-precaching": "^7.4.1",
    "workbox-routing": "^7.4.1",
    "workbox-strategies": "^7.4.1"
  },
  "scripts": {
    "preinstall": "node scripts/preinstall.js",
    "build-ergogen": "./patch/patch_ergogen.sh",
    "generate-previews": "ts-node --project scripts/tsconfig.json scripts/generate-previews.js",
    "postinstall": "node scripts/postinstall.js && pnpm run build-ergogen",
    "prestart": "pnpm run build-ergogen && pnpm run generate-previews",
    "start": "vite",
    "dev": "vite",
    "prebuild": "pnpm run build-ergogen && pnpm run generate-previews",
    "build": "vite build",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "test": "pnpm test:unit && pnpm test:e2e",
    "predeploy": "pnpm run build",
    "deploy": "gh-pages -d dist",
    "format": "prettier --write \"*.{js,ts,json,md}\" \"{src,e2e,patch}/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "lint:js": "eslint --fix \"{src,e2e,patch}/**/*.{ts,tsx,js,jsx}\"",
    "lint:md": "markdownlint --fix \"**/*.md\"",
    "lint": "pnpm lint:md && pnpm lint:js && pnpm knip",
    "precommit": "pnpm format && pnpm lint && pnpm test:unit"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@playwright/test": "^1.55.1",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^15.0.2",
    "@testing-library/user-event": "^14.5.2",
    "@types/file-saver": "^2.0.7",
    "@types/js-yaml": "^4.0.9",
    "@types/lodash-es": "^4.17.12",
    "@types/lodash.debounce": "^4.0.9",
    "@types/react": "^18.2.0",
    "@types/styled-components": "^5.1.34",
    "@typescript-eslint/eslint-plugin": "^8.45.0",
    "@typescript-eslint/parser": "^8.45.0",
    "@vitejs/plugin-react": "^4.3.3",
    "baseline-browser-mapping": "^2.10.43",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jest": "^29.0.1",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^6.2.0-canary-4fdf7cf2-20251003",
    "gh-pages": "^6.1.1",
    "globals": "^16.4.0",
    "jsdom": "^29.1.1",
    "knip": "^5.64.1",
    "markdownlint": "^0.38.0",
    "markdownlint-cli": "^0.45.0",
    "prettier": "^3.6.2",
    "three-stdlib": "^2.36.0",
    "ts-node": "^10.9.2",
    "typescript-eslint": "^8.45.0",
    "vite": "^5.4.11",
    "vite-plugin-pwa": "^0.21.1",
    "vitest": "^2.1.4"
  }
}
